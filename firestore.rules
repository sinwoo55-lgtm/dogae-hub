rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 학교망을 확인한 Vercel API가 발급한 짧은 수명의 읽기 전용 토큰만 허용한다.
    // 일정 외 데이터(특히 학생 명렬)는 계속 서버 API로만 접근한다.
    function scheduleReader() {
      return request.auth != null
        && request.auth.token.scheduleReader == true
        && request.auth.token.scheduleAccessUntil is int
        && request.time.toMillis() < request.auth.token.scheduleAccessUntil;
    }

    match /dashboard_posts/{postId} {
      allow read: if scheduleReader();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
