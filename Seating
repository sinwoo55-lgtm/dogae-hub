/* ══ 자동 배치 알고리즘 (1,500회 시뮬레이션) ══ */
function generateLayout(){
  students=collectStudents();
  var rows=parseInt(document.getElementById('sRows').value)||5;
  var cols=parseInt(document.getElementById('sCols').value)||6;
  var genderSep=document.getElementById('optGender').checked;

  settings={rows,cols,emptySeats,fixedSeats,pairs,genderSep,colGaps:colGaps.slice(),rowGaps:rowGaps.slice()};

  // 배치 가능한 학생 목록
  var activeStudents=students.filter(function(s){return!s.absent&&s.name;});
  var totalSeats=rows*cols;
  var emptySet=new Set(emptySeats);
  var validSeats=[];
  for(var r=1;r<=rows;r++){
    for(var c=1;c<=cols;c++){
      if(!emptySet.has(c+'-'+r)) validSeats.push({r,c});
    }
  }
  if(activeStudents.length>validSeats.length){
    alert('학생 수('+activeStudents.length+'명)가 유효 자리 수('+validSeats.length+'개)보다 많아요. 행/열을 늘려주세요.');
    return;
  }

  var best=null, bestScore=-1;
  var SIMS=1500;

  for(var sim=0;sim<SIMS;sim++){
    var grid=buildGrid(rows,cols,emptySeats);
    var placed=tryPlace(grid,activeStudents,validSeats,fixedSeats,pairs,genderSep,rows,cols);
    if(!placed) continue;
    var score=scoreLayout(grid,rows,cols);
    if(score>bestScore){bestScore=score;best=JSON.parse(JSON.stringify(grid));}
  }

  if(!best){
    alert('제약 조건이 너무 많아 배치가 불가능해요. 고정/짝 조건을 줄여보세요.');
    return;
  }

  layout=best;
  document.getElementById('layoutBadge').textContent=curClass+' 학급 배치표';
  renderSeatGrid();
  goScreen('screenLayout');
}

function buildGrid(rows,cols,emptySeats){
  var grid=[];
  var emptySet=new Set(emptySeats);
  for(var r=1;r<=rows;r++){
    var row=[];
    for(var c=1;c<=cols;c++){
      row.push(emptySet.has(c+'-'+r)?'EMPTY':null);
    }
    grid.push(row);
  }
  return grid;
}

function tryPlace(grid,students,validSeats,fixedSeats,pairs,genderSep,rows,cols){
  // 1. 고정 좌석 먼저
  var usedNames=new Set();
  for(var fi=0;fi<fixedSeats.length;fi++){
    var f=fixedSeats[fi];
    if(f.row<1||f.row>rows||f.col<1||f.col>cols) continue;
    if(grid[f.row-1][f.col-1]==='EMPTY') continue;
    grid[f.row-1][f.col-1]=f.name;
    usedNames.add(f.name);
  }

  // 2. 남은 학생 및 빈 자리
  var remaining=students.filter(function(s){return!usedNames.has(s.name);});
  var freeSeats=validSeats.filter(function(s){return grid[s.r-1][s.c-1]===null;});

  // 남녀 분리
  if(genderSep){
    var males=remaining.filter(function(s){return s.gender==='M';});
    var females=remaining.filter(function(s){return s.gender!=='M';});
    var half=Math.floor(freeSeats.length/2);
    var leftSeats=freeSeats.filter(function(s){return s.c<=Math.ceil(cols/2);});
    var rightSeats=freeSeats.filter(function(s){return s.c>Math.ceil(cols/2);});
    shuffle(leftSeats); shuffle(rightSeats); shuffle(males); shuffle(females);
    var maleSeats=leftSeats.length>=males.length?leftSeats:freeSeats.slice(0,half);
    var femaleSeats=rightSeats.length>=females.length?rightSeats:freeSeats.slice(half);
    place(grid,males,maleSeats); place(grid,females,femaleSeats);
  } else {
    shuffle(remaining); shuffle(freeSeats);
    // 짝 고정 처리
    var pairPlaced=new Set();
    for(var pi=0;pi<pairs.length;pi++){
      var pa=pairs[pi];
      var sA=remaining.find(function(s){return s.name===pa.a;});
      var sB=remaining.find(function(s){return s.name===pa.b;});
      if(!sA||!sB) continue;
      // 인접 빈 자리 쌍 찾기
      for(var si=0;si<freeSeats.length-1;si++){
        var s1=freeSeats[si], s2=freeSeats[si+1];
        if(grid[s1.r-1][s1.c-1]||grid[s2.r-1][s2.c-1]) continue;
        if(s1.r===s2.r&&Math.abs(s1.c-s2.c)===1){
          grid[s1.r-1][s1.c-1]=sA.name;
          grid[s2.r-1][s2.c-1]=sB.name;
          pairPlaced.add(sA.name);pairPlaced.add(sB.name);
          break;
        }
      }
    }
    var leftover=remaining.filter(function(s){return!pairPlaced.has(s.name);});
    var leftFree=freeSeats.filter(function(s){return grid[s.r-1][s.c-1]===null;});
    place(grid,leftover,leftFree);
  }
  return true;
}

function place(grid,students,seats){
  for(var i=0;i<students.length&&i<seats.length;i++){
    grid[seats[i].r-1][seats[i].c-1]=students[i].name;
  }
}
function shuffle(arr){for(var i=arr.length-1;i>0;i--){var j=Math.floor(Math.random()*(i+1));var t=arr[i];arr[i]=arr[j];arr[j]=t;}return arr;}
function scoreLayout(grid,rows,cols){
  // 점수: 빈 자리 없이 채워진 정도 (단순 랜덤 다양성)
  return Math.random();
}

/* ══ 배치표 렌더링 ══ */
function renderSeatGrid(){
  var grid=document.getElementById('seatGrid');
  grid.innerHTML='';
  var rows=settings.rows, cols=settings.cols;
  var colGapSet=new Set(settings.colGaps||[]);
  var rowGapSet=new Set(settings.rowGaps||[]);
  var fixedSet={};
  (settings.fixedSeats||[]).forEach(function(f){fixedSet[f.col+'-'+f.row]=f.name;});

  for(var r=1;r<=rows;r++){
    // 행 구분선
    if(rowGapSet.has(r-1)){
      var spacer=document.createElement('div');
      spacer.className='gap-row-spacer';
      spacer.innerHTML='<div class="gap-row-spacer-line"></div>';
      grid.appendChild(spacer);
    }

    var rowEl=document.createElement('div');
    rowEl.className='seat-row';

    for(var c=1;c<=cols;c++){
      // 열 구분선
      if(colGapSet.has(c-1)){
        var colGapEl=document.createElement('div');
        colGapEl.className='seat-col-gap';
        colGapEl.innerHTML='<div class="seat-col-gap-line"></div>';
        rowEl.appendChild(colGapEl);
      }

      var name=layout[r-1][c-1];
      var seat=document.createElement('div');
      seat.className='seat';
      seat.dataset.r=r; seat.dataset.c=c;

      if(name==='EMPTY'){
        seat.classList.add('empty');
        seat.textContent='빈 자리';
      } else if(name){
        var stu=students.find(function(s){return s.name===name;});
        var gender=stu?stu.gender:'';
        if(gender==='M') seat.classList.add('male');
        else if(gender==='F') seat.classList.add('female');
        if(fixedSet[c+'-'+r]===name) seat.classList.add('fixed-seat');
        // 학번 표시
        var num=stu?stu.num:'';
        seat.innerHTML='<span class="seat-num">'+num+'</span>'+esc(name);
        seat.draggable=true;
        seat.addEventListener('dragstart',onDragStart);
        seat.addEventListener('dragover',onDragOver);
        seat.addEventListener('drop',onDrop);
        seat.addEventListener('dragend',onDragEnd);
      } else {
        seat.classList.add('empty');
        seat.style.opacity='.3';
      }
      rowEl.appendChild(seat);
    }
    grid.appendChild(rowEl);
  }
}

/* ══ 드래그 앤 드롭 ══ */
function onDragStart(e){
  dragSrc=this;
  this.classList.add('dragging');
  e.dataTransfer.effectAllowed='move';
}
function onDragOver(e){
  e.preventDefault();
  if(this!==dragSrc&&!this.classList.contains('empty')){
    this.classList.add('drag-over');
  }
}
function onDrop(e){
  e.preventDefault();
  if(!dragSrc||this===dragSrc||this.classList.contains('empty')) return;
  var r1=parseInt(dragSrc.dataset.r)-1, c1=parseInt(dragSrc.dataset.c)-1;
  var r2=parseInt(this.dataset.r)-1,   c2=parseInt(this.dataset.c)-1;
  var tmp=layout[r1][c1];
  layout[r1][c1]=layout[r2][c2];
  layout[r2][c2]=tmp;
  renderSeatGrid();
}
function onDragEnd(){
  document.querySelectorAll('.seat').forEach(function(s){
    s.classList.remove('dragging','drag-over');
  });
  dragSrc=null;
}

/* ══ 저장 / 히스토리 ══ */
function saveLayout(){
  document.getElementById('saveLabel').value='';
  document.getElementById('saveModal').classList.add('active');
  setTimeout(function(){document.getElementById('saveLabel').focus();},160);
}
function closeSaveModal(){document.getElementById('saveModal').classList.remove('active');}
function confirmSave(){
  var label=document.getElementById('saveLabel').value.trim()||nowStr();
  var data={
    students:students,
    settings:settings,
    currentLayout:layout,
    savedAt:firebase.firestore.FieldValue.serverTimestamp()
  };
  var docRef=db.collection('seating_classes').doc(curClass);
  docRef.set(data,{merge:true}).then(function(){
    // 히스토리 추가
    return docRef.collection('history').add({
      label:label,
      layout:layout,
      savedAt:firebase.firestore.FieldValue.serverTimestamp()
    });
  }).then(function(){
    closeSaveModal();
    showToast('💾 저장 완료!');
    loadHistory();
  }).catch(function(err){alert('저장 오류: '+err.message);});
}

function loadHistory(){
  db.collection('seating_classes').doc(curClass).collection('history')
    .orderBy('savedAt','desc').limit(20).get().then(function(snap){
    var list=document.getElementById('historyList');
    list.innerHTML='';
    if(snap.empty){list.innerHTML='<p style="font-size:12px;color:var(--muted);padding:12px">저장된 기록이 없어요</p>';return;}
    snap.docs.forEach(function(d){
      var item=document.createElement('div');
      item.className='history-item';
      var date=d.data().savedAt?d.data().savedAt.toDate().toLocaleDateString('ko-KR'):'';
      item.innerHTML='<div class="history-item-date">'+esc(d.data().label||date)+'</div><div class="history-item-label">'+date+'</div>';
      item.addEventListener('click',function(){
        if(!confirm('이 배치로 복원할까요?')) return;
        layout=d.data().layout;
        renderSeatGrid();
        showToast('복원 완료!');
      });
      list.appendChild(item);
    });
  });
}

function toggleHistory(){
  var panel=document.getElementById('historyPanel');
  var show=panel.style.display==='none'||!panel.style.display;
  panel.style.display=show?'flex':'none';
  if(show) loadHistory();
}

/* ══ 인쇄 ══ */
function printLayout(){window.print();}

document.addEventListener('keydown',function(e){
  if(e.key==='Escape') closeSaveModal();
});
document.getElementById('saveModal').addEventListener('click',function(e){
  if(e.target===this) closeSaveModal();
});
</script>
